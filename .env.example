APP_ENV=development

# ==============================================================================
# server
# ==============================================================================
SERVER_PORT=8080
HOST_PORT=8082

# ==============================================================================
# redis
# ==============================================================================
REDIS_ADDR=redis-local:6379
REDIS_PASSWORD=pwd

# ==============================================================================
# cors
# ==============================================================================
ALLOWED_ORIGINS=http://localhost:3000

# ==============================================================================
# rate limit (requests per window per IP)
# ==============================================================================
RATE_LIMIT_GET_MAX=100
RATE_LIMIT_POST_MAX=5
RATE_LIMIT_WINDOW_SEC=60